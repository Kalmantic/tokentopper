{
  "name": "tokentopper",
  "version": "0.6.1",
  "description": "Professional AI Usage Index for Claude Code, Codex, OpenCode, and Gemini CLI. Measure token usage, run-rate, tier, and verified shareable rank. More AI coding tools are on the roadmap. Private by default: prompts and code never leave your machine.",
  "type": "module",
  "bin": {
    "tokentopper": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "workflow:check": "node scripts/workflow-security-check.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "pack:check": "npm run build && node scripts/pack-check.mjs",
    "release:assets": "node scripts/build-release-assets.mjs",
    "release:verify-assets": "node scripts/verify-github-release-assets.mjs",
    "prerelease:prepare": "node scripts/prepare-prerelease.mjs",
    "jsr:verify": "node scripts/verify-jsr-release.mjs",
    "standalone:build": "bun scripts/build-standalone.mjs",
    "standalone:check": "node scripts/standalone-check.mjs",
    "standalone:package": "node scripts/package-standalone.mjs",
    "standalone:archive-check": "node scripts/standalone-archive-check.mjs",
    "standalone:candidates-check": "node scripts/verify-standalone-candidate-set.mjs",
    "check": "npm run workflow:check && npm run typecheck && npm test && npm run pack:check",
    "dev": "node --experimental-strip-types src/cli.ts",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-usage",
    "codex",
    "codex-usage",
    "opencode",
    "opencode-usage",
    "gemini",
    "gemini-cli",
    "gemini-cli-usage",
    "anthropic",
    "openai",
    "tokens",
    "token-usage",
    "token-tracker",
    "ai-usage",
    "usage-tracker",
    "usage",
    "cost",
    "ai",
    "ai-coding",
    "coding-agent",
    "llm",
    "leaderboard",
    "tokenmaxxing",
    "ccusage",
    "analytics",
    "cli",
    "developer-tools",
    "developer-productivity",
    "openfactoryai"
  ],
  "homepage": "https://openfactoryai.com/tools/tokentopper/",
  "bugs": {
    "url": "https://github.com/Kalmantic/tokentopper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kalmantic/tokentopper.git"
  },
  "author": "Kalmantic",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
